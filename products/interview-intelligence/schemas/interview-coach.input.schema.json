{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "interview-coach.input.schema.json",
  "title": "Interview Excellence Coach \u2014 Input",
  "description": "Interviewer-scoped coaching inputs. v1 (2026-07-18).",
  "type": "object",
  "required": [
    "interviewerGuide",
    "transcript"
  ],
  "properties": {
    "interviewerGuide": {
      "type": "string",
      "description": "Role, competencies to assess, pre-defined questions."
    },
    "transcript": {
      "type": "string"
    },
    "notes": {
      "type": "string",
      "description": "Optional recording insights or notes."
    },
    "language": {
      "type": "string"
    }
  }
}
