{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "job-description.intake.schema.json",
  "title": "Job Description — Intake & Coverage Record",
  "description": "v2 (2026-07-18). Full record of a NEW JOB intake session against the Job Discovery Questionnaire (question bank v2, IDs 'section.question' e.g. '2.3'). Durable artifact consumed by downstream agents (competency-builder, panel-designer, interview-system, feedback, rationale). Coverage lists EVERY questionnaire ID with a final status.",
  "type": "object",
  "required": ["roleTitle", "sessionDate", "openBrief", "answers", "coverage"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2.0" },
    "roleTitle": { "type": "string" },
    "companyName": { "type": "string" },
    "sessionDate": { "type": "string", "format": "date" },
    "language": { "type": "string", "description": "Output language of the session/JD (default 'en')." },
    "openBrief": {
      "type": "object",
      "description": "The hiring manager's initial free-form description of the role.",
      "properties": {
        "form": { "type": "string", "enum": ["text", "recording-transcript"] },
        "content": { "type": "string" }
      },
      "required": ["form", "content"]
    },
    "answers": {
      "type": "array",
      "description": "One entry per questionnaire item that received a real answer — from the open brief, the interview, or credited from elsewhere in the conversation.",
      "items": {
        "type": "object",
        "required": ["questionId", "question", "answer", "tag", "source"],
        "properties": {
          "questionId": { "type": "string", "pattern": "^\\d{1,2}\\.\\d{1,2}$", "description": "Question bank v2 ID, e.g. '5.2'." },
          "question": { "type": "string" },
          "answer": { "type": "string" },
          "tag": { "type": "string", "enum": ["public", "internal"] },
          "source": { "type": "string", "enum": ["open-brief", "interview", "inferred"] }
        }
      }
    },
    "coverage": {
      "type": "array",
      "description": "Exactly one entry per question ID in question bank v2 — the completion proof. Every ID must appear.",
      "items": {
        "type": "object",
        "required": ["questionId", "status"],
        "properties": {
          "questionId": { "type": "string", "pattern": "^\\d{1,2}\\.\\d{1,2}$" },
          "status": { "type": "string", "enum": ["answered", "inferred", "unknown", "not_yet_decided", "skipped"] }
        }
      }
    },
    "companyInfo": {
      "type": "object",
      "description": "Manual-entry block (pasted by the HM).",
      "properties": {
        "industry": { "type": "string" },
        "size": { "type": "string" },
        "benefits": { "type": "string" },
        "deiPolicy": { "type": "string" },
        "applicationProcess": { "type": "string" }
      }
    },
    "functionDescription": { "type": "string", "description": "Manual-entry block (pasted by the HM)." }
  }
}
