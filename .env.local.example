# Copy to .env.local (gitignored) and fill in — never commit real keys.
ANTHROPIC_API_KEY=sk-ant-...

# Clerk (auth) — create a free app at https://dashboard.clerk.com, then
# API Keys tab has both of these. Publishable key is safe to expose to
# the browser (that's what NEXT_PUBLIC_ means); secret key is not.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ElevenLabs (voice, ADR-005) — one-time manual setup, see docs/platform-architecture/Voice.md:
# 1. Create an account at https://elevenlabs.io and copy your API key (Settings > API Keys).
# 2. Create a Conversational AI Agent in their dashboard. Keep it PRIVATE (not public) —
#    our /api/job-description/voice-token route is the only intended way in.
# 3. In the Agent's "Custom LLM" settings, set the server URL to
#    <your-app-url>/api/job-description/voice-llm and Model ID to job-description-agent.
#    Generate a random secret (e.g. `openssl rand -hex 32`), enter it as the Agent's
#    Custom LLM secret/API key, and paste the SAME value below.
# 4. Copy the Agent's ID from its dashboard page into ELEVENLABS_AGENT_ID below.
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=agent_...
ELEVENLABS_CUSTOM_LLM_SECRET=...
